[Unit]
Description=DrukMix Moonraker Agent
After=network-online.target moonraker.service
Wants=network-online.target
Requires=moonraker.service

[Service]
Type=simple
User=dan
WorkingDirectory=/home/dan/drukmix
Environment=DRUKMIX_CONFIG=/home/dan/printer_data/config/drukmix.cfg
ExecStart=/usr/bin/python3 /home/dan/drukmix/drukmix_agent.py
Restart=always
RestartSec=2
Nice=5

[Install]
WantedBy=multi-user.target
