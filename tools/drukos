#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="${HOME}/drukmix"
CFG_DST="${HOME}/printer_data/config/drukmix.cfg"
MACROS_DST="${HOME}/printer_data/config/drukmix_macros.cfg"
SERVICE_DST="/etc/systemd/system/drukmix.service"

require_repo() {
  test -d "$REPO_DIR/.git"
}

copy_files() {
  cp -f "$REPO_DIR/config/drukmix.cfg" "$CFG_DST"
  cp -f "$REPO_DIR/config/drukmix_macros.cfg" "$MACROS_DST"
  sudo cp -f "$REPO_DIR/systemd/drukmix.service" "$SERVICE_DST"

  python3 -m py_compile \
    "$REPO_DIR/drukmix_agent.py" \
    "$REPO_DIR/backend/pump_backend_base.py" \
    "$REPO_DIR/backend/backend_pumpvfd.py" \
    "$REPO_DIR/backend/backend_pumptpl.py" \
    "$REPO_DIR/backend/bridge_usb_transport.py" \
    "$REPO_DIR/backend/agent_core_logic.py" \
    "$REPO_DIR/backend/vfd_faults.py"
}

ensure_macro_include() {
  python3 - <<'PY'
from pathlib import Path
p = Path("/home/dan/printer_data/config/printer.cfg")
lines = p.read_text().splitlines()

out = []
seen_macros = False
for line in lines:
    s = line.strip()
    if s == "[include drukmix.cfg]":
        continue
    if s == "[include drukmix_macros.cfg]":
        if seen_macros:
            continue
        seen_macros = True
    out.append(line)

if not seen_macros:
    out.append("[include drukmix_macros.cfg]")

p.write_text("\n".join(out) + "\n")
print("printer.cfg normalized")
PY
}

reload_klipper() {
  curl -s -X POST localhost:7125/printer/gcode/script \
    -H 'Content-Type: application/json' \
    -d '{"script":"FIRMWARE_RESTART"}' >/dev/null || true
}

restart_stack() {
  sudo systemctl daemon-reload
  sudo systemctl enable drukmix.service >/dev/null 2>&1 || true
  sudo systemctl restart moonraker
  sudo systemctl restart drukmix.service
}

show_status() {
  echo
  echo "== git =="
  git -C "$REPO_DIR" rev-parse --short HEAD || true

  echo
  echo "== moonraker =="
  curl -s localhost:7125/server/info || true
  echo

  echo
  echo "== drukmix.service =="
  systemctl status drukmix.service --no-pager -l || true

  echo
  echo "== last drukmix log =="
  tail -n 60 "$HOME/printer_data/logs/drukmix.log" || true
}

do_update() {
  require_repo
  git -C "$REPO_DIR" pull --ff-only
  copy_files
  ensure_macro_include
  reload_klipper
  restart_stack
  show_status
}

do_install() {
  require_repo
  copy_files
  ensure_macro_include
  reload_klipper
  restart_stack
  show_status
}

do_upgrade() {
  require_repo
  git -C "$REPO_DIR" fetch --all --tags
  git -C "$REPO_DIR" pull --ff-only
  copy_files
  ensure_macro_include
  reload_klipper
  restart_stack
  show_status
}

do_restart() {
  restart_stack
  show_status
}

do_logs() {
  tail -f "$HOME/printer_data/logs/drukmix.log"
}

case "${1:-}" in
  install) do_install ;;
  update)  do_update ;;
  upgrade) do_upgrade ;;
  restart) do_restart ;;
  status)  show_status ;;
  logs)    do_logs ;;
  *)
    echo "usage: drukos {install|update|upgrade|restart|status|logs}"
    exit 1
    ;;
esac
