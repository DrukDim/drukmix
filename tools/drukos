#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="/home/drukos/drukmix"

APP_DIR="/opt/drukmix"
CFG_DIR="/etc/drukmix"
LOG_DIR="/var/log/drukmix"

CFG_DST="$CFG_DIR/drukmix.cfg"
MACROS_DST_ETC="$CFG_DIR/drukmix_macros.cfg"
MACROS_DST_KLIPPER="$HOME/printer_data/config/drukmix_macros.cfg"
SERVICE_DST="/etc/systemd/system/drukmix.service"

require_repo() {
  test -d "$REPO_DIR/.git"
}

require_user() {
  if [[ "$(id -un)" != "drukos" ]]; then
    echo "Run this script as user 'drukos'"
    exit 2
  fi
}

prepare_dirs() {
  sudo mkdir -p "$APP_DIR" "$CFG_DIR" "$LOG_DIR"
  sudo chown -R drukos:drukos "$APP_DIR" "$CFG_DIR" "$LOG_DIR"
  sudo chmod 755 "$APP_DIR" "$CFG_DIR" "$LOG_DIR"
  sudo touch "$LOG_DIR/drukmix.log"
  sudo chown drukos:drukos "$LOG_DIR/drukmix.log"
  sudo chmod 644 "$LOG_DIR/drukmix.log"
}

copy_runtime() {
  rsync -a --delete \
    --exclude '.git' \
    --exclude '.pio' \
    --exclude '__pycache__' \
    --exclude '*.pyc' \
    --exclude 'firmware/releases' \
    "$REPO_DIR/" "$APP_DIR/"
}

write_release_manifest() {
  python3 - <<PY
import json
import subprocess
from pathlib import Path
from datetime import datetime, UTC

repo = Path("$REPO_DIR")
app = Path("$APP_DIR")

def sh(cmd):
    return subprocess.check_output(cmd, text=True).strip()

commit = sh(["git", "-C", str(repo), "rev-parse", "HEAD"])
short_commit = sh(["git", "-C", str(repo), "rev-parse", "--short", "HEAD"])

try:
    dirty = bool(sh(["git", "-C", str(repo), "status", "--porcelain"]))
except Exception:
    dirty = None

manifest = {
    "app": "drukmix",
    "source_repo": str(repo),
    "deployed_to": str(app),
    "git_commit": commit,
    "git_short": short_commit,
    "git_dirty": dirty,
    "deployed_at_utc": datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ"),
}

(app / ".release.json").write_text(json.dumps(manifest, indent=2) + "\n")
print("wrote", app / ".release.json")
PY
}

copy_configs() {
  sudo cp -f "$REPO_DIR/config/drukmix.cfg" "$CFG_DST"
  sudo cp -f "$REPO_DIR/config/drukmix_macros.cfg" "$MACROS_DST_ETC"
  sudo cp -f "$REPO_DIR/config/drukmix_macros.cfg" "$MACROS_DST_KLIPPER"
  sudo cp -f "$REPO_DIR/systemd/drukmix.service" "$SERVICE_DST"
  sudo chown drukos:drukos "$CFG_DST" "$MACROS_DST_ETC" "$MACROS_DST_KLIPPER"
}

patch_installed_cfg() {
  sudo python3 - <<'PY'
from pathlib import Path

p = Path("/etc/drukmix/drukmix.cfg")
s = p.read_text()

repl = {
    "/home/dan/": "/home/drukos/",
    "serial_port = /dev/serial/by-id/usb-Silicon_Labs_CP2102_USB_to_UART_Bridge_Controller_0001-if00-port0": "serial_port = /dev/drukos-bridge",
    "log_file = /home/drukos/printer_data/logs/drukmix.log": "log_file = /var/log/drukmix/drukmix.log",
    "log_file = /home/dan/printer_data/logs/drukmix.log": "log_file = /var/log/drukmix/drukmix.log",
}

for a, b in repl.items():
    s = s.replace(a, b)

if "printer_cfg = /home/dan/printer_data/config/printer.cfg" in s:
    s = s.replace(
        "printer_cfg = /home/dan/printer_data/config/printer.cfg",
        "printer_cfg = /home/drukos/printer_data/config/printer.cfg"
    )

if "printer_cfg = /home/drukos/printer_data/config/printer.cfg" not in s:
    s += "\nprinter_cfg = /home/drukos/printer_data/config/printer.cfg\n"

if "log_file = /var/log/drukmix/drukmix.log" not in s:
    s += "\nlog_file = /var/log/drukmix/drukmix.log\n"

if "serial_port = /dev/drukos-bridge" not in s:
    s = s.replace("serial_port = /dev/ttyUSB0", "serial_port = /dev/drukos-bridge")

p.write_text(s)
print("patched /etc/drukmix/drukmix.cfg")
PY
}

ensure_macro_include() {
  python3 - <<'PY'
from pathlib import Path

p = Path("/home/drukos/printer_data/config/printer.cfg")
lines = p.read_text().splitlines()

needle = "[include drukmix_macros.cfg]"
out = []
seen = False

for line in lines:
    if line.strip() == needle:
        if seen:
            continue
        seen = True
    out.append(line)

if not seen:
    out.append(needle)

p.write_text("\n".join(out) + "\n")
print("printer.cfg normalized")
PY
}

ensure_venv() {
  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 not found"
    exit 2
  fi

  if ! python3 -m venv --help >/dev/null 2>&1; then
    echo "python3-venv is required"
    echo "Install with: sudo apt-get update && sudo apt-get install -y python3-venv"
    exit 2
  fi

  if [[ ! -x "$APP_DIR/.venv/bin/python" ]]; then
    python3 -m venv "$APP_DIR/.venv"
  fi

  "$APP_DIR/.venv/bin/python" -m pip install --upgrade pip setuptools wheel

  if [[ -f "$APP_DIR/requirements.txt" ]]; then
    "$APP_DIR/.venv/bin/pip" install -r "$APP_DIR/requirements.txt"
  fi
}

compile_check() {
  "$APP_DIR/.venv/bin/python" -m py_compile \
    "$APP_DIR/drukmix_agent.py" \
    "$APP_DIR/backend/pump_backend_base.py" \
    "$APP_DIR/backend/backend_pumpvfd.py" \
    "$APP_DIR/backend/backend_pumptpl.py" \
    "$APP_DIR/backend/bridge_usb_transport.py" \
    "$APP_DIR/backend/agent_core_logic.py" \
    "$APP_DIR/backend/vfd_faults.py"
}

reload_klipper() {
  curl -s -X POST localhost:7125/printer/gcode/script \
    -H 'Content-Type: application/json' \
    -d '{"script":"FIRMWARE_RESTART"}' >/dev/null || true
}

restart_stack() {
  sudo systemctl daemon-reload
  sudo systemctl enable drukmix.service >/dev/null 2>&1 || true
  sudo systemctl restart moonraker
  sudo systemctl restart drukmix.service
}

show_status() {
  echo
  echo "== repo git =="
  git -C "$REPO_DIR" rev-parse --short HEAD || true

  echo
  echo "== deployed release manifest =="
  sed -n '1,200p' "$APP_DIR/.release.json" 2>/dev/null || true

  echo
  echo "== moonraker =="
  curl -s localhost:7125/server/info || true
  echo

  echo
  echo "== drukmix.service =="
  systemctl status drukmix.service --no-pager -l || true

  echo
  echo "== /etc/drukmix/drukmix.cfg =="
  sed -n '1,220p' "$CFG_DST" || true

  echo
  echo "== last drukmix log =="
  tail -n 80 "$LOG_DIR/drukmix.log" || true
}

do_install() {
  require_user
  require_repo
  prepare_dirs
  copy_runtime
  write_release_manifest
  copy_configs
  patch_installed_cfg
  ensure_macro_include
  ensure_venv
  compile_check
  reload_klipper
  restart_stack
  show_status
}

do_update() {
  require_user
  require_repo
  git -C "$REPO_DIR" pull --ff-only
  prepare_dirs
  copy_runtime
  write_release_manifest
  sudo cp -f "$REPO_DIR/systemd/drukmix.service" "$SERVICE_DST"
  sudo chown drukos:drukos "$SERVICE_DST" || true
  ensure_venv
  compile_check
  restart_stack
  show_status
}

do_upgrade() {
  require_user
  require_repo
  git -C "$REPO_DIR" fetch --all --tags
  git -C "$REPO_DIR" pull --ff-only
  prepare_dirs
  copy_runtime
  write_release_manifest
  sudo cp -f "$REPO_DIR/systemd/drukmix.service" "$SERVICE_DST"
  sudo chown drukos:drukos "$SERVICE_DST" || true
  ensure_venv
  compile_check
  restart_stack
  show_status
}

do_restart() {
  restart_stack
  show_status
}

do_status() {
  show_status
}

do_logs() {
  tail -f "$LOG_DIR/drukmix.log"
}

case "${1:-}" in
  install) do_install ;;
  update)  do_update ;;
  upgrade) do_upgrade ;;
  restart) do_restart ;;
  status)  do_status ;;
  logs)    do_logs ;;
  *)
    echo "usage: drukos {install|update|upgrade|restart|status|logs}"
    exit 1
    ;;
esac
