#!/usr/bin/env bash
#
# DrukMix setup helper
# - Installs Klipper extra `drukmix_controller.py` into klippy/extras
# - Copies example configs (controller, macros, driver) if missing
# - Adds printer.cfg includes if missing
# - (Optional) installs a systemd service for the driver
#
# Defaults can be overridden via env:
#   PRINTER_CFG_DIR   (default: $HOME/printer_data/config)
#   KLIPPER_ROOT      (default: $HOME/klipper)
#   DRUKMIX_REPO_ROOT (default: parent of this script)
#   DRUKMIX_CONFIG    (driver cfg path; default: $PRINTER_CFG_DIR/drukmix_driver.cfg)
#
# Usage:
#   ./tools/drukmix-setup [--force] [--install-service]
#
# Notes:
# - Files are only created if missing unless --force is passed.
# - systemd unit requires root; run under sudo if installing service.
set -euo pipefail

REPO_ROOT="${DRUKMIX_REPO_ROOT:-"$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"}"
RUN_AS_USER="${SUDO_USER:-$(id -un)}"
if command -v getent >/dev/null 2>&1; then
  USER_HOME="$(getent passwd "$RUN_AS_USER" | cut -d: -f6)"
else
  USER_HOME="$(eval echo "~$RUN_AS_USER")"
fi
if [[ -z "$USER_HOME" || ! -d "$USER_HOME" ]]; then
  USER_HOME="$HOME"
fi
PRINTER_CFG_DIR="${PRINTER_CFG_DIR:-"$USER_HOME/printer_data/config"}"
KLIPPER_ROOT="${KLIPPER_ROOT:-"$USER_HOME/klipper"}"
KLIPPER_EXTRAS_DIR="${KLIPPER_EXTRAS_DIR:-"$KLIPPER_ROOT/klippy/extras"}"

if [[ ! -d "$PRINTER_CFG_DIR" ]]; then
  for alt in \
    "$USER_HOME/printer_data/config" \
    "/home/klipper/printer_data/config" \
    "/home/pi/printer_data/config"
  do
    if [[ -d "$alt" ]]; then
      PRINTER_CFG_DIR="$alt"
      break
    fi
  done
fi

PRINTER_CFG_PATH="${PRINTER_CFG_DIR}/printer.cfg"
CONTROLLER_SRC="${REPO_ROOT}/klipper_extra/drukmix_controller.py"
CONTROLLER_DST="${KLIPPER_EXTRAS_DIR}/drukmix_controller.py"

MACROS_SRC="${REPO_ROOT}/config_examples/drukmix_macros.cfg"
MACROS_DST="${PRINTER_CFG_DIR}/drukmix_macros.cfg"

CTRL_CFG_SRC="${REPO_ROOT}/config_examples/drukmix_controller.cfg"
CTRL_CFG_DST="${PRINTER_CFG_DIR}/drukmix_controller.cfg"

DRIVER_CFG_SRC="${REPO_ROOT}/config_examples/drukmix_driver.cfg"
DRIVER_CFG_DST="${DRUKMIX_CONFIG:-"$PRINTER_CFG_DIR/drukmix_driver.cfg"}"

SERVICE_NAME="drukmix.service"
SERVICE_PATH="/etc/systemd/system/${SERVICE_NAME}"
AGENT_BIN="${REPO_ROOT}/drukmix_driver.py"

FORCE=0
INSTALL_SERVICE=0
SYMLINK_CONTROLLER=0
FORCE_DRIVER_CFG=0

log() { printf "[drukmix-setup] %s\n" "$*" >&2; }
die() { log "ERROR: $*"; exit 1; }

usage() {
  cat >&2 <<EOF
Usage: $0 [--force] [--force-driver-cfg] [--force-agent-cfg] [--symlink-controller] [--install-service] [--help]
  --force               overwrite existing files (configs/unit/controller/unit)
  --force-driver-cfg     overwrite existing drukmix_driver.cfg
  --force-agent-cfg      legacy alias for --force-driver-cfg
  --symlink-controller  place controller as symlink into klippy/extras
  --install-service     install systemd service for drukmix driver
  --help                show this help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --force)
      FORCE=1
      ;;
    --force-driver-cfg)
      FORCE_DRIVER_CFG=1
      ;;
    --force-agent-cfg)
      FORCE_DRIVER_CFG=1
      ;;
    --symlink-controller)
      SYMLINK_CONTROLLER=1
      ;;
    --install-service)
      INSTALL_SERVICE=1
      ;;
    --help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
  shift
done

ensure_dir() { [[ -d "$1" ]] || mkdir -p "$1"; }

copy_if_missing() {
  local src="$1" dst="$2"
  if [[ -e "$dst" && $FORCE -eq 0 ]]; then
    log "skip (exists): $dst"
    return
  fi
  ensure_dir "$(dirname "$dst")"
  cp "$src" "$dst"
  log "installed: $dst"
}

copy_force() {
  local src="$1" dst="$2"
  ensure_dir "$(dirname "$dst")"
  cp "$src" "$dst"
  log "installed: $dst"
}

require_path() { [[ -e "$1" ]] || die "missing: $1"; }

append_include_if_missing() {
  local include_line="$1"
  local cfg="$2"
  ensure_dir "$(dirname "$cfg")"
  touch "$cfg"
  if grep -Fqx "$include_line" "$cfg"; then
    log "include already present: $include_line"
  else
    echo "$include_line" >> "$cfg"
    log "added include to $(basename "$cfg"): $include_line"
  fi
}

install_controller() {
  require_path "$CONTROLLER_SRC"
  # autodetect extras dir if the hinted one is missing
  if [[ ! -d "$KLIPPER_EXTRAS_DIR" ]]; then
    for alt in \
      "$KLIPPER_ROOT/klippy/extras" \
      "$HOME/klipper/klippy/extras" \
      "/usr/share/klipper/klippy/extras"
    do
      if [[ -d "$alt" ]]; then
        KLIPPER_EXTRAS_DIR="$alt"
        break
      fi
    done
  fi
  ensure_dir "$KLIPPER_EXTRAS_DIR"
  if [[ -e "$CONTROLLER_DST" && $FORCE -eq 0 ]]; then
    log "controller exists, use --force to overwrite: $CONTROLLER_DST"
  else
    if [[ $SYMLINK_CONTROLLER -eq 1 ]]; then
      ln -sf "$CONTROLLER_SRC" "$CONTROLLER_DST"
      log "symlinked controller extra: $CONTROLLER_DST -> $CONTROLLER_SRC"
    else
      cp "$CONTROLLER_SRC" "$CONTROLLER_DST"
      log "installed controller extra: $CONTROLLER_DST"
    fi
  fi
}

install_configs() {
  copy_force "$MACROS_SRC" "$MACROS_DST"
  copy_if_missing "$CTRL_CFG_SRC" "$CTRL_CFG_DST"
  if [[ -e "$DRIVER_CFG_DST" && $FORCE_DRIVER_CFG -eq 0 ]]; then
    log "skip (exists): $DRIVER_CFG_DST"
  else
    copy_if_missing "$DRIVER_CFG_SRC" "$DRIVER_CFG_DST"
  fi
  append_include_if_missing "[include $(basename "$CTRL_CFG_DST")]" "$PRINTER_CFG_PATH"
  append_include_if_missing "[include $(basename "$MACROS_DST")]" "$PRINTER_CFG_PATH"
}

install_service() {
  require_path "$AGENT_BIN"
  if ! command -v systemctl >/dev/null 2>&1; then
    log "systemctl not found; skipping service install"
    return
  fi
  if [[ $EUID -ne 0 ]]; then
    log "not root; skipping service install (rerun with sudo or install manually)"
    return
  fi
  local cfg_path="$DRIVER_CFG_DST"
  local python_bin="/usr/bin/python3"
  if [[ -x "${REPO_ROOT}/.venv/bin/python" ]]; then
    python_bin="${REPO_ROOT}/.venv/bin/python"
  fi
  local unit_content="[Unit]
Description=DrukMix driver
After=network-online.target moonraker.service
Wants=network-online.target

[Service]
Type=simple
User=${SUDO_USER:-$(id -un)}
Environment=DRUKMIX_CONFIG=${cfg_path}
ExecStart=${python_bin} ${AGENT_BIN}
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
"
  if [[ -e "$SERVICE_PATH" && $FORCE -eq 0 ]]; then
    log "service exists, use --force to overwrite: $SERVICE_PATH"
  else
    echo "$unit_content" | tee "$SERVICE_PATH" >/dev/null
    log "installed service unit: $SERVICE_PATH"
    systemctl daemon-reload
    systemctl enable "$SERVICE_NAME"
    log "service enabled (not started): $SERVICE_NAME"
  fi
}

main() {
  install_controller
  install_configs
  if [[ $INSTALL_SERVICE -eq 1 ]]; then
    install_service
  fi
  log "done. Next steps:"
  log "  - restart klipper to load extra (e.g., systemctl restart klipper)"
  if [[ $INSTALL_SERVICE -eq 1 ]]; then
    log "  - start driver: sudo systemctl start ${SERVICE_NAME}"
  else
    log "  - run driver manually: DRUKMIX_CONFIG=${DRIVER_CFG_DST} python3 ${AGENT_BIN}"
  fi
}

main "$@"
