compute_summary_state() {
  if [[ ! -f "$DRIVER_CFG_DST" && ! -f "$CONTROLLER_CFG_DST" && ! -f "$MACROS_DST" && ! -f "$SERVICE_DST" ]]; then
    printf 'NOT_INSTALLED'
    return 0
  fi
  if ! klipper_ready; then
    printf 'BLOCKED'
    return 0
  fi
  if bridge_alias_exists && [[ "$(service_state drukmix.service)" == "active" ]]; then
    printf 'READY'
    return 0
  fi
  printf 'PARTIAL'
}

cmd_help() {
  cat <<'EOF'
DrukMix CLI

Usage:
  drukmix help
  drukmix check
  drukmix install <profile>
  drukmix uninstall
  drukmix flash bridge        (not implemented yet)
  drukmix flash tpl           (not implemented yet)
  drukmix flash vfd           (not implemented yet)

Profiles:
  main
  brama
  duet

Notes:
  - This tool works from the local repo checkout.
  - Repo updates are expected to come from Moonraker update_manager.
  - For an easier shell command, run: ./tools/drukmix-setup
EOF
}

cmd_check() {
  print_header "Repo"
  if git -C "$REPO_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    print_ok "path" "$REPO_DIR"
    print_info "branch" "$(repo_branch)"
    print_info "commit" "$(repo_commit)"
    if [[ "$(repo_dirty)" == "clean" ]]; then
      print_ok "worktree" "clean"
    else
      print_warn "worktree" "dirty"
    fi
  else
    print_missing "repo" "$REPO_DIR"
  fi

  print_header "Host Install"
  file_state "$DRIVER_CFG_DST" "driver cfg"
  file_state "$CONTROLLER_CFG_DST" "controller cfg"
  file_state "$MACROS_DST" "macros cfg"
  file_state "$SERVICE_DST" "service unit"
  file_state "$UDEV_RULE_DST" "bridge udev"
  if has_moonraker_update_manager; then
    print_ok "moonraker entry" "$MOONRAKER_CFG"
  else
    print_missing "moonraker entry" "$MOONRAKER_CFG"
  fi

  print_header "Klipper Integration"
  file_state "$KLIPPER_EXTRA_DST" "planner extra"
  file_state "$KLIPPER_CONTROLLER_DST" "controller extra"
  if printer_cfg_has_line "[include drukmix_controller.cfg]"; then
    print_ok "controller include" "$PRINTER_CFG"
  else
    print_missing "controller include" "$PRINTER_CFG"
  fi
  if printer_cfg_has_line "[include drukmix_macros.cfg]"; then
    print_ok "macros include" "$PRINTER_CFG"
  else
    print_missing "macros include" "$PRINTER_CFG"
  fi
  if printer_cfg_has_managed_probe_block; then
    print_ok "managed probe" "$PRINTER_CFG"
  else
    print_missing "managed probe" "$PRINTER_CFG"
  fi

  print_header "Hardware"
  if bridge_alias_exists; then
    print_ok "bridge alias" "$BRIDGE_ALIAS"
  else
    print_missing "bridge alias" "$BRIDGE_ALIAS"
  fi
  if bridge_usb_visible; then
    print_ok "bridge usb" "visible in /dev/serial/by-id"
  else
    print_warn "bridge usb" "not detected"
  fi
  print_info "pump" "unknown"

  print_header "Runtime"
  if moonraker_reachable; then
    print_ok "moonraker" "$MOONRAKER_URL"
  else
    print_missing "moonraker" "$MOONRAKER_URL"
  fi
  if klipper_ready; then
    print_ok "klipper" "ready"
  else
    print_warn "klipper" "not ready"
  fi
  case "$(service_runtime_state drukmix.service)" in
    active)
      print_ok "drukmix.service" "active"
      ;;
    restart-loop)
      print_warn "drukmix.service" "restart-loop"
      ;;
    failed)
      print_warn "drukmix.service" "failed"
      ;;
    inactive|not-installed|unavailable|unknown)
      print_info "drukmix.service" "$(service_runtime_state drukmix.service)"
      ;;
    *)
      print_info "drukmix.service" "$(service_runtime_state drukmix.service)"
      ;;
  esac

  print_header "Summary"
  case "$(compute_summary_state)" in
    READY)
      print_ok "state" "READY"
      ;;
    PARTIAL)
      print_warn "state" "PARTIAL"
      print_info "next step" "install runtime or connect bridge hardware"
      ;;
    BLOCKED)
      print_warn "state" "BLOCKED"
      print_info "next step" "restore klipper/moonraker readiness first"
      ;;
    *)
      print_info "state" "NOT_INSTALLED"
      print_info "next step" "run 'drukmix install <profile>'"
      ;;
  esac
}

cmd_install() {
  local profile="${1:-}"
  if [[ -z "$profile" ]]; then
    echo "Usage: drukmix install <profile>"
    exit 2
  fi
  if ! profile_supported "$profile"; then
    echo "Unsupported profile: $profile"
    exit 2
  fi

  print_step "Preflight"
  require_repo_layout
  require_printer_stack_paths
  require_python
  ensure_sudo_session
  if [[ "$profile" != "main" ]]; then
    print_info "profile" "$profile uses core install only for now"
  fi

  print_step "Python Environment"
  ensure_venv
  compile_check
  print_ok "venv" "$REPO_DIR/.venv"

  print_step "Core Install"
  install_cfg_if_missing
  patch_driver_cfg
  install_klipper_extras
  install_service_unit
  install_bridge_udev_rule
  reload_udev_rules
  moonraker_write_update_manager
  patch_mainsail_pause_no_park
  ensure_printer_integration
  print_ok "moonraker entry" "$MOONRAKER_CFG"

  print_step "Runtime"
  restart_moonraker_if_possible
  restart_klipper_if_possible
  wait_klipper_ready || true
  enable_runtime_if_ready

  cmd_check
}

cmd_uninstall() {
  local artifacts=()
  [[ -f "$SERVICE_DST" ]] && artifacts+=("service:$SERVICE_DST")
  [[ -f "$UDEV_RULE_DST" ]] && artifacts+=("udev:$UDEV_RULE_DST")
  [[ -f "$DRIVER_CFG_DST" ]] && artifacts+=("driver_cfg:$DRIVER_CFG_DST")
  [[ -f "$CONTROLLER_CFG_DST" ]] && artifacts+=("controller_cfg:$CONTROLLER_CFG_DST")
  [[ -f "$MACROS_DST" ]] && artifacts+=("macros_cfg:$MACROS_DST")
  [[ -f "$KLIPPER_EXTRA_DST" ]] && artifacts+=("planner_extra:$KLIPPER_EXTRA_DST")
  [[ -f "$KLIPPER_CONTROLLER_DST" ]] && artifacts+=("controller_extra:$KLIPPER_CONTROLLER_DST")
  printer_cfg_has_line "[include drukmix_controller.cfg]" && artifacts+=("printer_include:drukmix_controller.cfg")
  printer_cfg_has_line "[include drukmix_macros.cfg]" && artifacts+=("printer_include:drukmix_macros.cfg")
  printer_cfg_has_managed_probe_block && artifacts+=("printer_probe_block:$PRINTER_CFG")
  has_moonraker_update_manager && artifacts+=("moonraker_entry:$MOONRAKER_CFG")
  [[ -d "$REPO_DIR/.venv" ]] && artifacts+=("venv:$REPO_DIR/.venv")
  [[ -f "$PRINTER_LOG_DIR/drukmix_driver.log" ]] && artifacts+=("log:$PRINTER_LOG_DIR/drukmix_driver.log")
  [[ -d "$REPO_DIR" ]] && artifacts+=("repo:$REPO_DIR")

  print_header "Uninstall Plan"
  if [[ ${#artifacts[@]} -eq 0 ]]; then
    print_info "state" "no DrukMix artifacts detected"
    return 0
  fi
  printf '%s\n' "${artifacts[@]}"
  printf '\nType YES to uninstall DrukMix: '
  read -r reply
  if [[ "$reply" != "YES" ]]; then
    echo "Cancelled."
    exit 2
  fi
  ensure_sudo_session

  print_step "Removing Runtime"
  if command -v systemctl >/dev/null 2>&1; then
    sudo systemctl stop drukmix.service >/dev/null 2>&1 || true
    sudo systemctl disable drukmix.service >/dev/null 2>&1 || true
  fi
  sudo rm -f "$SERVICE_DST"
  sudo systemctl daemon-reload >/dev/null 2>&1 || true
  sudo rm -f "$UDEV_RULE_DST"
  reload_udev_rules

  print_step "Removing Files"
  remove_file_if_exists "$DRIVER_CFG_DST"
  remove_file_if_exists "$CONTROLLER_CFG_DST"
  remove_file_if_exists "$MACROS_DST"
  remove_file_if_exists "$KLIPPER_EXTRA_DST"
  remove_file_if_exists "$KLIPPER_CONTROLLER_DST"
  remove_file_if_exists "$PRINTER_LOG_DIR/drukmix_driver.log"

  print_step "Normalizing Config"
  remove_printer_integration
  remove_update_manager_section
  restart_moonraker_if_possible
  restart_klipper_if_possible

  print_step "Removing Local Checkout"
  remove_path_any_owner "$REPO_DIR/.venv"

  print_step "Removing Repo"
  if [[ -d "$REPO_DIR" ]]; then
    ( sleep 1; remove_path_any_owner "$REPO_DIR" ) >/dev/null 2>&1 &
    print_ok "repo" "scheduled removal: $REPO_DIR"
  fi

  print_header "Summary"
  print_ok "state" "DrukMix uninstall completed"
}

cmd="${1:-help}"
case "$cmd" in
  help|-h|--help)
    cmd_help
    ;;
  check)
    cmd_check
    ;;
  install)
    cmd_install "${2:-}"
    ;;
  uninstall)
    cmd_uninstall
    ;;
  flash)
    echo "Not implemented yet: flash ${2:-}"
    exit 2
    ;;
  *)
    cmd_help
    exit 2
    ;;
esac
