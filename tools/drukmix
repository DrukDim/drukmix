#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
USER_NAME="$(id -un)"
USER_HOME="$(getent passwd "$USER_NAME" | cut -d: -f6)"
PRINTER_CFG_DIR="${PRINTER_CFG_DIR:-$USER_HOME/printer_data/config}"

CFG_TEMPLATE="$REPO_DIR/config/drukmix.cfg"
CFG_DST="$PRINTER_CFG_DIR/drukmix.cfg"

MACROS_SRC="$REPO_DIR/config/drukmix_macros.cfg"
MACROS_DST="$PRINTER_CFG_DIR/drukmix_macros.cfg"

PRINTER_CFG="$PRINTER_CFG_DIR/printer.cfg"
SERVICE_TEMPLATE="$REPO_DIR/systemd/drukmix.service"
SERVICE_DST="/etc/systemd/system/drukmix.service"

require_repo() {
  test -f "$REPO_DIR/drukmix_agent.py"
  test -f "$CFG_TEMPLATE"
  test -f "$MACROS_SRC"
  test -f "$SERVICE_TEMPLATE"
}

require_paths() {
  if [[ ! -d "$PRINTER_CFG_DIR" ]]; then
    echo "Printer config dir not found: $PRINTER_CFG_DIR"
    exit 2
  fi
  if [[ ! -f "$PRINTER_CFG" ]]; then
    echo "printer.cfg not found: $PRINTER_CFG"
    exit 2
  fi
}

ensure_python() {
  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 not found"
    exit 2
  fi
  if ! python3 -m venv --help >/dev/null 2>&1; then
    echo "python3-venv is required"
    echo "Install with: sudo apt-get update && sudo apt-get install -y python3-venv"
    exit 2
  fi
}

ensure_venv() {
  ensure_python

  if [[ ! -x "$REPO_DIR/.venv/bin/python" ]]; then
    python3 -m venv "$REPO_DIR/.venv"
  fi

  "$REPO_DIR/.venv/bin/python" -m pip install --upgrade pip setuptools wheel

  if [[ -f "$REPO_DIR/requirements.txt" ]]; then
    "$REPO_DIR/.venv/bin/pip" install -r "$REPO_DIR/requirements.txt"
  fi
}

compile_check() {
  "$REPO_DIR/.venv/bin/python" -m py_compile \
    "$REPO_DIR/drukmix_agent.py" \
    "$REPO_DIR/backend/pump_backend_base.py" \
    "$REPO_DIR/backend/backend_pumpvfd.py" \
    "$REPO_DIR/backend/backend_pumptpl.py" \
    "$REPO_DIR/backend/bridge_usb_transport.py" \
    "$REPO_DIR/backend/agent_core_logic.py" \
    "$REPO_DIR/backend/vfd_faults.py"
}

install_cfg_if_missing() {
  if [[ ! -f "$CFG_DST" ]]; then
    cp "$CFG_TEMPLATE" "$CFG_DST"
    echo "Installed default config: $CFG_DST"
  else
    echo "Keeping existing config: $CFG_DST"
  fi
}

patch_cfg() {
  python3 - <<PY
from pathlib import Path
import os

p = Path(os.environ["CFG_DST"])
user_home = os.environ["USER_HOME"]
s = p.read_text()

repl = {
    "/home/dan/": user_home + "/",
    "/home/drukos/": user_home + "/",
    "printer_cfg = /home/dan/printer_data/config/printer.cfg": f"printer_cfg = {user_home}/printer_data/config/printer.cfg",
    "printer_cfg = /home/drukos/printer_data/config/printer.cfg": f"printer_cfg = {user_home}/printer_data/config/printer.cfg",
}

for a, b in repl.items():
    s = s.replace(a, b)

if "printer_cfg =" not in s:
    s += f"\nprinter_cfg = {user_home}/printer_data/config/printer.cfg\n"

p.write_text(s)
print(f"patched {p}")
PY
}

install_macros_link() {
  rm -f "$MACROS_DST"
  ln -s "$MACROS_SRC" "$MACROS_DST"
  echo "Linked macros: $MACROS_DST -> $MACROS_SRC"
}

ensure_macro_include() {
  python3 - <<PY
from pathlib import Path
import os

p = Path(os.environ["PRINTER_CFG"])
needle = "[include drukmix_macros.cfg]"

lines = p.read_text().splitlines()
out = []
seen = False

for line in lines:
    if line.strip() == needle:
        if seen:
            continue
        seen = True
    out.append(line)

if not seen:
    out.append(needle)

p.write_text("\\n".join(out) + "\\n")
print(f"normalized {p}")
PY
}

install_service() {
  sudo install -m 0644 "$SERVICE_TEMPLATE" "$SERVICE_DST"
  sudo systemctl daemon-reload
  sudo systemctl enable drukmix.service >/dev/null 2>&1 || true
}

restart_service() {
  sudo systemctl restart drukmix.service
}

reload_klipper() {
  curl -s -X POST localhost:7125/printer/gcode/script \
    -H 'Content-Type: application/json' \
    -d '{"script":"FIRMWARE_RESTART"}' >/dev/null || true
}

do_install() {
  require_repo
  require_paths
  ensure_venv
  compile_check
  install_cfg_if_missing
  CFG_DST="$CFG_DST" USER_HOME="$USER_HOME" patch_cfg
  install_macros_link
  PRINTER_CFG="$PRINTER_CFG" ensure_macro_include
  install_service
  reload_klipper
  restart_service
  do_status
}

do_update() {
  require_repo
  require_paths
  git -C "$REPO_DIR" pull --ff-only
  ensure_venv
  compile_check
  install_macros_link
  install_service
  restart_service
  do_status
}

do_purge() {
  sudo systemctl stop drukmix.service >/dev/null 2>&1 || true
  sudo systemctl disable drukmix.service >/dev/null 2>&1 || true
  sudo rm -f "$SERVICE_DST"
  sudo systemctl daemon-reload

  if [[ -L "$MACROS_DST" || -f "$MACROS_DST" ]]; then
    rm -f "$MACROS_DST"
    echo "Removed macros file/link: $MACROS_DST"
  fi

  echo
  echo "Purge completed."
  echo "Kept repo: $REPO_DIR"
  echo "Kept venv: $REPO_DIR/.venv"
  echo "Kept config: $CFG_DST"
  echo "printer.cfg was not modified except possible existing include line."
  echo
  echo "To remove repo-local venv too, run:"
  echo "  rm -rf '$REPO_DIR/.venv'"
}

do_restart() {
  restart_service
  do_status
}

do_status() {
  echo
  echo "== repo =="
  echo "$REPO_DIR"
  git -C "$REPO_DIR" rev-parse --short HEAD || true

  echo
  echo "== user =="
  echo "$USER_NAME"
  echo "$USER_HOME"

  echo
  echo "== paths =="
  echo "printer cfg dir: $PRINTER_CFG_DIR"
  echo "config: $CFG_DST"
  echo "macros: $MACROS_DST"
  echo "service: $SERVICE_DST"

  echo
  echo "== service =="
  systemctl status drukmix.service --no-pager -l || true

  echo
  echo "== moonraker server/info =="
  curl -s localhost:7125/server/info || true
  echo

  echo
  echo "== config preview =="
  sed -n '1,220p' "$CFG_DST" || true
}

do_logs() {
  journalctl -u drukmix.service -n 100 -f
}

do_doctor() {
  echo "== doctor =="
  echo

  command -v python3 >/dev/null 2>&1 && echo "python3: ok" || echo "python3: missing"
  command -v curl >/dev/null 2>&1 && echo "curl: ok" || echo "curl: missing"
  [[ -x "$REPO_DIR/.venv/bin/python" ]] && echo "venv: ok" || echo "venv: missing"
  [[ -f "$CFG_DST" ]] && echo "config: ok ($CFG_DST)" || echo "config: missing ($CFG_DST)"
  [[ -f "$PRINTER_CFG" ]] && echo "printer.cfg: ok ($PRINTER_CFG)" || echo "printer.cfg: missing ($PRINTER_CFG)"
  [[ -L "$MACROS_DST" || -f "$MACROS_DST" ]] && echo "macros: ok ($MACROS_DST)" || echo "macros: missing ($MACROS_DST)"
  [[ -f "$SERVICE_DST" ]] && echo "service file: ok ($SERVICE_DST)" || echo "service file: missing ($SERVICE_DST)"

  echo
  echo "Moonraker:"
  curl -s localhost:7125/server/info || true
  echo
}

case "${1:-}" in
  install) do_install ;;
  update)  do_update ;;
  purge)   do_purge ;;
  restart) do_restart ;;
  status)  do_status ;;
  logs)    do_logs ;;
  doctor)  do_doctor ;;
  *)
    echo "usage: drukmix {install|update|purge|restart|status|logs|doctor}"
    exit 1
    ;;
esac
