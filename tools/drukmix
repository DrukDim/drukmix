#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
USER_NAME="$(id -un)"
EFFECTIVE_USER="${SUDO_USER:-$USER_NAME}"
USER_HOME=""

if [[ -z "${SUDO_USER:-}" && -n "${HOME:-}" ]]; then
  USER_HOME="$HOME"
fi
if [[ -z "$USER_HOME" ]]; then
  USER_HOME="$(getent passwd "$EFFECTIVE_USER" | cut -d: -f6 || true)"
fi
if [[ -z "$USER_HOME" ]]; then
  USER_HOME="$(python3 -c "import pwd; print(pwd.getpwnam('${EFFECTIVE_USER}').pw_dir)")"
fi
if [[ -z "$USER_HOME" ]]; then
  echo "Cannot determine user home directory"
  exit 2
fi

PRINTER_CFG_DIR="${PRINTER_CFG_DIR:-$USER_HOME/printer_data/config}"
PRINTER_LOG_DIR="${PRINTER_LOG_DIR:-$USER_HOME/printer_data/logs}"

DRIVER_CFG_TEMPLATE="$REPO_DIR/config_examples/drukmix_driver.cfg"
CONTROLLER_CFG_TEMPLATE="$REPO_DIR/config_examples/drukmix_controller.cfg"
MACROS_TEMPLATE="$REPO_DIR/config_examples/drukmix_macros.cfg"

DRIVER_CFG_DST="$PRINTER_CFG_DIR/drukmix_driver.cfg"
CONTROLLER_CFG_DST="$PRINTER_CFG_DIR/drukmix_controller.cfg"
MACROS_DST="$PRINTER_CFG_DIR/drukmix_macros.cfg"
LEGACY_PLANNER_DST="$PRINTER_CFG_DIR/drukmix_planner.cfg"

PRINTER_CFG="$PRINTER_CFG_DIR/printer.cfg"
SERVICE_TEMPLATE="$REPO_DIR/systemd/drukmix.service"
SERVICE_DST="/etc/systemd/system/drukmix.service"

KLIPPER_DIR="${KLIPPER_DIR:-$USER_HOME/klipper}"
KLIPPER_EXTRA_SRC="$REPO_DIR/klipper_extra/drukmix_planner_probe.py"
KLIPPER_EXTRA_DST="$KLIPPER_DIR/klippy/extras/drukmix_planner_probe.py"
KLIPPER_CONTROLLER_SRC="$REPO_DIR/klipper_extra/drukmix_controller.py"
KLIPPER_CONTROLLER_DST="$KLIPPER_DIR/klippy/extras/drukmix_controller.py"
KLIPPER_VEXT_DST="$KLIPPER_DIR/klippy/extras/drukmix_virtual_extruder.py"

require_repo() {
  test -f "$REPO_DIR/drukmix_driver.py"
  test -f "$DRIVER_CFG_TEMPLATE"
  test -f "$CONTROLLER_CFG_TEMPLATE"
  test -f "$MACROS_TEMPLATE"
  test -f "$SERVICE_TEMPLATE"
}

require_paths() {
  if [[ ! -d "$PRINTER_CFG_DIR" ]]; then
    echo "Printer config dir not found: $PRINTER_CFG_DIR"
    exit 2
  fi
  if [[ ! -d "$PRINTER_LOG_DIR" ]]; then
    echo "Printer log dir not found: $PRINTER_LOG_DIR"
    exit 2
  fi
  if [[ ! -f "$PRINTER_CFG" ]]; then
    echo "printer.cfg not found: $PRINTER_CFG"
    exit 2
  fi
}

ensure_python() {
  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 not found"
    exit 2
  fi
  if ! python3 -m venv --help >/dev/null 2>&1; then
    echo "python3-venv is required"
    echo "Install with: sudo apt-get update && sudo apt-get install -y python3-venv"
    exit 2
  fi
}

ensure_venv() {
  ensure_python

  if [[ ! -x "$REPO_DIR/.venv/bin/python" ]]; then
    python3 -m venv "$REPO_DIR/.venv"
  fi

  "$REPO_DIR/.venv/bin/python" -m pip install --upgrade pip setuptools wheel

  if [[ -f "$REPO_DIR/requirements.txt" ]]; then
    "$REPO_DIR/.venv/bin/pip" install -r "$REPO_DIR/requirements.txt"
  fi
}

compile_check() {
  "$REPO_DIR/.venv/bin/python" -m py_compile \
    "$REPO_DIR/drukmix_driver.py" \
    "$REPO_DIR/backend/pump_backend_base.py" \
    "$REPO_DIR/backend/backend_pumpvfd.py" \
    "$REPO_DIR/backend/backend_pumptpl.py" \
    "$REPO_DIR/backend/bridge_usb_transport.py" \
    "$REPO_DIR/backend/agent_core_logic.py" \
    "$REPO_DIR/backend/vfd_faults.py"
}

install_cfg_if_missing() {
  if [[ ! -f "$DRIVER_CFG_DST" ]]; then
    cp "$DRIVER_CFG_TEMPLATE" "$DRIVER_CFG_DST"
    echo "Installed default driver config: $DRIVER_CFG_DST"
  else
    echo "Keeping existing driver config: $DRIVER_CFG_DST"
  fi

  if [[ ! -f "$CONTROLLER_CFG_DST" ]]; then
    cp "$CONTROLLER_CFG_TEMPLATE" "$CONTROLLER_CFG_DST"
    echo "Installed default controller config: $CONTROLLER_CFG_DST"
  else
    echo "Keeping existing controller config: $CONTROLLER_CFG_DST"
  fi
}

install_macros_if_missing() {
  if [[ ! -f "$MACROS_DST" ]]; then
    cp "$MACROS_TEMPLATE" "$MACROS_DST"
    echo "Installed default macros: $MACROS_DST"
  else
    echo "Keeping existing macros: $MACROS_DST"
  fi
}

remove_file_if_present() {
  local path="$1"
  rm -f "$path"
}

sync_repo_ff_only() {
  if ! git -C "$REPO_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 0
  fi
  if ! git -C "$REPO_DIR" remote get-url origin >/dev/null 2>&1; then
    return 0
  fi

  if ! git -C "$REPO_DIR" pull --ff-only; then
    echo "WARNING: install could not fast-forward repo (dirty tree or divergence), continuing with current checkout"
  fi
}

remove_include_line() {
  local include_line="$1"
  PRINTER_CFG="$PRINTER_CFG" INCLUDE_LINE="$include_line" python3 - <<'PY2'
from pathlib import Path
import os

p = Path(os.environ["PRINTER_CFG"])
needle = os.environ["INCLUDE_LINE"]

lines = p.read_text().splitlines()
out = [line for line in lines if line.strip() != needle]
p.write_text("\n".join(out) + "\n")
print(f"normalized {p} without {needle}")
PY2
}

patch_cfg_if_needed() {
  DRIVER_CFG_DST="$DRIVER_CFG_DST" USER_HOME="$USER_HOME" PRINTER_LOG_DIR="$PRINTER_LOG_DIR" python3 - <<'PY'
from pathlib import Path
import os

p = Path(os.environ["DRIVER_CFG_DST"])
user_home = os.environ["USER_HOME"]
log_dir = os.environ["PRINTER_LOG_DIR"]
log_file = f"{log_dir}/drukmix_driver.log"

s = p.read_text()

repl = {
    "/home/dan/": user_home + "/",
    "/home/drukos/": user_home + "/",
    "/root/": user_home + "/",
    "log_file = /var/log/drukmix/drukmix_driver.log": f"log_file = {log_file}",
    "log_file = /home/drukos/printer_data/logs/drukmix_driver.log": f"log_file = {log_file}",
    "log_file = /home/dan/printer_data/logs/drukmix_driver.log": f"log_file = {log_file}",
    "log_file = /root/printer_data/logs/drukmix_driver.log": f"log_file = {log_file}",
}

for a, b in repl.items():
    s = s.replace(a, b)

if "log_file =" not in s:
    s += f"\nlog_file = {log_file}\n"

if "client_name =" not in s:
    s += "\nclient_name = drukmix_driver\n"
if "client_version =" not in s:
    s += "client_version = 1.0\n"
if "client_type =" not in s:
    s += "client_type = agent\n"
if "client_url =" not in s:
    s += "client_url = http://127.0.0.1\n"

p.write_text(s)
print(f"patched {p}")
PY
}

ensure_include_once() {
  local include_line="$1"
  PRINTER_CFG="$PRINTER_CFG" INCLUDE_LINE="$include_line" python3 - <<'PY'
from pathlib import Path
import os

p = Path(os.environ["PRINTER_CFG"])
needle = os.environ["INCLUDE_LINE"]

lines = p.read_text().splitlines()
out = []
seen = False

for line in lines:
    if line.strip() == needle:
        if seen:
            continue
        seen = True
    out.append(line)

if not seen:
    out.append(needle)

p.write_text("\n".join(out) + "\n")
print(f"normalized {p} with {needle}")
PY
}

normalize_controller_cfg() {
  CONTROLLER_CFG_DST="$CONTROLLER_CFG_DST" python3 - <<'PY'
from pathlib import Path
import os

p = Path(os.environ["CONTROLLER_CFG_DST"])
if not p.exists():
    raise SystemExit(0)

lines = p.read_text().splitlines()
out = []
for line in lines:
    stripped = line.strip()
    if not stripped:
        out.append(line)
        continue
    if stripped.startswith("#"):
        if "Planner probe tuning" in stripped or "planner_probe_" in stripped:
            continue
        out.append(line)
        continue
    key = stripped.split(":", 1)[0].split("=", 1)[0].strip()
    if key in (
        "planner_probe_host_buffer_target_s",
        "planner_probe_print_velocity_epsilon",
        "planner_probe_print_gap_merge_s",
    ):
        continue
    out.append(line)

p.write_text("\n".join(out) + "\n")
print(f"normalized {p} without planner probe keys")
PY
}

ensure_required_includes() {
  ensure_include_once "[include drukmix_controller.cfg]"
  ensure_include_once "[include drukmix_macros.cfg]"
  remove_include_line "[include drukmix_research.cfg]"
  remove_include_line "[include drukmix_planner.cfg]"
  ensure_planner_probe_section
}

ensure_planner_probe_section() {
  PRINTER_CFG="$PRINTER_CFG" CONTROLLER_CFG_DST="$CONTROLLER_CFG_DST" python3 - <<'PY'
from pathlib import Path
import os
import re
import configparser

p = Path(os.environ["PRINTER_CFG"])
s = p.read_text()

controller_cfg = Path(os.environ.get("CONTROLLER_CFG_DST", ""))
pump_start_lookahead_s = 3.0
host_buffer_target_s = 0.0
print_velocity_epsilon = 0.001
print_gap_merge_s = 0.75
if controller_cfg.exists():
  cp = configparser.ConfigParser(inline_comment_prefixes=("#", ";"))
  try:
    cp.read(controller_cfg)
    if cp.has_section("drukmix_controller"):
      pump_start_lookahead_s = cp.getfloat("drukmix_controller", "pump_start_lookahead_s", fallback=3.0)
  except Exception:
    pump_start_lookahead_s = 3.0

if host_buffer_target_s <= 0.0:
  host_buffer_target_s = pump_start_lookahead_s

host_buffer_target_s = max(0.0, min(30.0, float(host_buffer_target_s)))
print_velocity_epsilon = max(0.0, min(0.1, float(print_velocity_epsilon)))
print_gap_merge_s = max(0.0, min(30.0, float(print_gap_merge_s)))


begin = "# --- drukmix planner probe (managed): begin ---"
end = "# --- drukmix planner probe (managed): end ---"
block = f"""# --- drukmix planner probe (managed): begin ---
[drukmix_planner_probe]
extruder = extruder
debug_enabled = False
debug_every_n_moves = 200
print_velocity_epsilon = {print_velocity_epsilon:.6f}
print_gap_merge_s = {print_gap_merge_s:.3f}
host_buffer_target_s = {host_buffer_target_s:.3f}
# --- drukmix planner probe (managed): end ---"""

# Remove any old managed block variant.
if begin in s and end in s:
  a = s.index(begin)
  b = s.index(end) + len(end)
  s = (s[:a] + s[b:]).rstrip("\n") + "\n"

# Remove any unmanaged/legacy probe sections (including stale keys).
section_re = re.compile(r"(?ms)^\[drukmix_planner_probe\]\s*\n.*?(?=^\[|\Z)")
s = section_re.sub("", s).rstrip("\n")

# Insert exactly one canonical managed section.
s = s + "\n\n" + block + "\n"

p.write_text(s)
print(f"normalized {p} with managed [drukmix_planner_probe] section")
PY
}

remove_managed_planner_probe_section() {
  PRINTER_CFG="$PRINTER_CFG" python3 - <<'PY'
from pathlib import Path
import os

p = Path(os.environ["PRINTER_CFG"])
s = p.read_text()

begin = "# --- drukmix planner probe (managed): begin ---"
end = "# --- drukmix planner probe (managed): end ---"

if begin in s and end in s:
    a = s.index(begin)
    b = s.index(end) + len(end)
    s = (s[:a] + s[b:]).strip("\n") + "\n"
    p.write_text(s)
    print(f"normalized {p} without managed [drukmix_planner_probe] section")
PY
}

install_service() {
  local rendered
  rendered="$(mktemp)"

  # Render unit for current host user and actual repo/config paths.
  sed \
    -e "s|^User=.*$|User=${USER_NAME}|" \
    -e "s|^WorkingDirectory=.*$|WorkingDirectory=${REPO_DIR}|" \
    -e "s|^Environment=.*$|Environment=DRUKMIX_CONFIG=${PRINTER_CFG_DIR}/drukmix_driver.cfg|" \
    -e "s|^ExecStart=.*$|ExecStart=${REPO_DIR}/.venv/bin/python ${REPO_DIR}/drukmix_driver.py|" \
    "$SERVICE_TEMPLATE" > "$rendered"

  sudo install -m 0644 "$rendered" "$SERVICE_DST"
  rm -f "$rendered"
  sudo systemctl daemon-reload
  sudo systemctl enable drukmix.service >/dev/null 2>&1 || true
}



restart_service() {
  sudo systemctl restart drukmix.service
}

restart_klipper() {
  curl -s -X POST localhost:7125/printer/gcode/script \
    -H 'Content-Type: application/json' \
    -d '{"script":"RESTART"}' >/dev/null
}

wait_klipper_ready() {
  local n=0
  while [[ $n -lt 60 ]]; do
    if curl -s localhost:7125/server/info | grep -q '"klippy_state":"ready"'; then
      return 0
    fi
    sleep 1
    n=$((n+1))
  done
  return 1
}

wait_for_bridge_alias() {
  local n=0
  while [[ $n -lt 20 ]]; do
    if [[ -e /dev/drukos-bridge ]]; then
      return 0
    fi
    sleep 0.5
    n=$((n+1))
  done
  return 1
}

install_bridge_udev_rule() {
  local rules_dir="/etc/udev/rules.d"
  local rules_file="${rules_dir}/99-drukos-bridge.rules"

  sudo mkdir -p "${rules_dir}"
  sudo tee "${rules_file}" >/dev/null <<'EOF'
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", ATTRS{serial}=="0001", SYMLINK+="drukos-bridge", MODE:="0660", GROUP:="dialout"
EOF
  sudo chmod 0644 "${rules_file}"
}

reload_udev_rules() {
  if ! command -v udevadm >/dev/null 2>&1; then
    return 0
  fi

  local rc=0

  sudo udevadm control --reload-rules >/dev/null 2>&1 || rc=$?
  if [[ $rc -ne 0 ]]; then
    echo "WARNING: udevadm control failed (rc=$rc), continuing"
  fi

  rc=0
  sudo udevadm trigger >/dev/null 2>&1 || rc=$?
  if [[ $rc -ne 0 ]]; then
    echo "WARNING: udevadm trigger failed (rc=$rc), continuing"
  fi

  rc=0
  udevadm settle >/dev/null 2>&1 || rc=$?
  if [[ $rc -ne 0 ]]; then
    echo "WARNING: udevadm settle failed (rc=$rc), continuing"
  fi
}

install_klipper_extra_if_present() {
  if [[ ! -f "$KLIPPER_EXTRA_SRC" ]]; then
    echo "klipper extra source missing: $KLIPPER_EXTRA_SRC"
    return 0
  fi

  if [[ ! -d "$KLIPPER_DIR/klippy/extras" ]]; then
    echo "klipper extras dir not found, skipping planner extra: $KLIPPER_DIR/klippy/extras"
    return 0
  fi

  install -m 0644 "$KLIPPER_EXTRA_SRC" "$KLIPPER_EXTRA_DST"
  echo "installed planner klipper extra: $KLIPPER_EXTRA_DST"
  if [[ -f "$KLIPPER_CONTROLLER_SRC" ]]; then
    install -m 0644 "$KLIPPER_CONTROLLER_SRC" "$KLIPPER_CONTROLLER_DST"
    echo "installed controller klipper extra: $KLIPPER_CONTROLLER_DST"
  fi

}

bridge_status() {
  if [[ -L /dev/drukos-bridge || -e /dev/drukos-bridge ]]; then
    echo "bridge alias: ok (/dev/drukos-bridge)"
    readlink -f /dev/drukos-bridge 2>/dev/null | sed 's/^/bridge target: /'
  else
    echo "bridge alias: missing (/dev/drukos-bridge)"
  fi

  if [[ -d /dev/serial/by-id ]]; then
    echo "serial by-id:"
    ls -1 /dev/serial/by-id 2>/dev/null | sed 's/^/  /' || true
  else
    echo "serial by-id: missing dir"
  fi
}

do_install() {
  require_repo
  require_paths
  sync_repo_ff_only
  ensure_venv
  compile_check
  install_cfg_if_missing
  install_macros_if_missing
  remove_file_if_present "$PRINTER_CFG_DIR/drukmix_research.cfg"
  remove_file_if_present "$LEGACY_PLANNER_DST"
  rm -f "$KLIPPER_VEXT_DST"
  patch_cfg_if_needed
  normalize_controller_cfg
  ensure_required_includes
  install_service
  install_bridge_udev_rule
  reload_udev_rules
  if wait_for_bridge_alias; then
    echo "bridge alias ready: /dev/drukos-bridge -> $(readlink -f /dev/drukos-bridge)"
  else
    echo "WARNING: /dev/drukos-bridge not present after install"
  fi
  install_klipper_extra_if_present
  restart_service
  restart_klipper
  if wait_klipper_ready; then
    echo "klipper ready after RESTART"
  else
    echo "WARNING: klipper did not report ready after RESTART"
  fi
  do_status
}

do_update() {
  require_repo
  require_paths
  git -C "$REPO_DIR" pull --ff-only
  ensure_venv
  compile_check
  remove_file_if_present "$PRINTER_CFG_DIR/drukmix_research.cfg"
  remove_file_if_present "$PRINTER_CFG_DIR/drukmix_planner.cfg"
  rm -f "$KLIPPER_VEXT_DST"
  patch_cfg_if_needed
  normalize_controller_cfg
  ensure_required_includes
  install_service
  install_bridge_udev_rule
  reload_udev_rules
  install_klipper_extra_if_present
  restart_service
  restart_klipper
  if wait_klipper_ready; then
    echo "klipper ready after RESTART"
  else
    echo "WARNING: klipper did not report ready after RESTART"
  fi
  do_status
}

do_purge() {
  sudo systemctl stop drukmix.service >/dev/null 2>&1 || true
  sudo systemctl disable drukmix.service >/dev/null 2>&1 || true
  sudo rm -f "$SERVICE_DST"
  sudo systemctl daemon-reload

  rm -f "$MACROS_DST"
  rm -f "$PRINTER_CFG_DIR/drukmix_planner.cfg"
  rm -f "$PRINTER_CFG_DIR/drukmix_research.cfg"
  rm -f "$KLIPPER_EXTRA_DST"
  rm -f "$KLIPPER_CONTROLLER_DST"
  rm -f "$KLIPPER_VEXT_DST"


  remove_include_line "[include drukmix_controller.cfg]"
  remove_include_line "[include drukmix_macros.cfg]"
  remove_include_line "[include drukmix_research.cfg]"
  remove_include_line "[include drukmix_planner.cfg]"
  remove_managed_planner_probe_section

  echo
  echo "Purge completed."
  echo "Kept repo: $REPO_DIR"
  echo "Kept venv: $REPO_DIR/.venv"
  echo "Kept driver config: $DRIVER_CFG_DST"
  echo "Kept controller config: $CONTROLLER_CFG_DST"
  echo "Removed live macros file: $MACROS_DST"
  echo "Removed managed planner-probe section from printer.cfg"
}

do_restart() {
  restart_service
  restart_klipper
  if wait_klipper_ready; then
    echo "klipper ready after RESTART"
  else
    echo "WARNING: klipper did not report ready after RESTART"
  fi
  do_status
}

do_status() {
  echo
  echo "== repo =="
  echo "$REPO_DIR"
  git -C "$REPO_DIR" rev-parse --short HEAD || true

  echo
  echo "== user =="
  echo "$USER_NAME"
  echo "$USER_HOME"

  echo
  echo "== paths =="
  echo "printer cfg dir: $PRINTER_CFG_DIR"
  echo "printer log dir: $PRINTER_LOG_DIR"
  echo "driver config: $DRIVER_CFG_DST"
  echo "controller config: $CONTROLLER_CFG_DST"
  echo "macros: $MACROS_DST"
  echo "service: $SERVICE_DST"

  echo "klipper dir: $KLIPPER_DIR"
  echo "planner klipper extra: $KLIPPER_EXTRA_DST"
  echo "controller klipper extra: $KLIPPER_CONTROLLER_DST"

  echo
  echo "== service =="
  systemctl status drukmix.service --no-pager -l || true

  echo
  echo "== moonraker server/info =="
  curl -s localhost:7125/server/info || true
  echo

  echo
  echo "== drukmix planner probe =="
  curl -s -X POST localhost:7125/printer/objects/query \
    -H 'Content-Type: application/json' \
    -d '{"objects":{"drukmix_planner_probe":["queue_tail_s","print_window_active","time_to_print_start_s","time_to_print_stop_s","control_velocity_mms"]}}' || true
  echo

  echo
  echo "== config preview (driver) =="
  sed -n '1,220p' "$DRIVER_CFG_DST" || true
  echo
  echo "== config preview (controller) =="
  sed -n '1,220p' "$CONTROLLER_CFG_DST" || true
}

do_logs() {
  tail -n 200 -F "$PRINTER_LOG_DIR/drukmix_driver.log"
}

do_doctor() {
  echo "== doctor =="
  echo

  command -v python3 >/dev/null 2>&1 && echo "python3: ok" || echo "python3: missing"
  command -v curl >/dev/null 2>&1 && echo "curl: ok" || echo "curl: missing"
  command -v getent >/dev/null 2>&1 && echo "getent: ok" || echo "getent: missing (fallbacks still exist)"
  command -v udevadm >/dev/null 2>&1 && echo "udevadm: ok" || echo "udevadm: missing"
  [[ -x "$REPO_DIR/.venv/bin/python" ]] && echo "venv: ok" || echo "venv: missing"
  [[ -f "$DRIVER_CFG_DST" ]] && echo "driver config: ok ($DRIVER_CFG_DST)" || echo "driver config: missing ($DRIVER_CFG_DST)"
  [[ -f "$CONTROLLER_CFG_DST" ]] && echo "controller config: ok ($CONTROLLER_CFG_DST)" || echo "controller config: missing ($CONTROLLER_CFG_DST)"
  [[ -f "$PRINTER_CFG" ]] && echo "printer.cfg: ok ($PRINTER_CFG)" || echo "printer.cfg: missing ($PRINTER_CFG)"
  [[ -f "$MACROS_DST" ]] && echo "macros: ok ($MACROS_DST)" || echo "macros: missing ($MACROS_DST)"
  [[ -f "$LEGACY_PLANNER_DST" ]] && echo "legacy planner config: present ($LEGACY_PLANNER_DST)" || echo "legacy planner config: not used"
  [[ -f "$SERVICE_DST" ]] && echo "service file: ok ($SERVICE_DST)" || echo "service file: missing ($SERVICE_DST)"

  [[ -f "$KLIPPER_EXTRA_DST" ]] && echo "planner klipper extra: ok ($KLIPPER_EXTRA_DST)" || echo "planner klipper extra: missing ($KLIPPER_EXTRA_DST)"
  [[ -f "$KLIPPER_CONTROLLER_DST" ]] && echo "controller klipper extra: ok ($KLIPPER_CONTROLLER_DST)" || echo "controller klipper extra: missing ($KLIPPER_CONTROLLER_DST)"


  echo
  bridge_status

  echo
  echo "Moonraker:"
  curl -s localhost:7125/server/info || true
  echo

  echo "drukmix planner probe:"
  curl -s -X POST localhost:7125/printer/objects/query \
    -H 'Content-Type: application/json' \
    -d '{"objects":{"drukmix_planner_probe":["queue_tail_s","print_window_active","time_to_print_start_s","time_to_print_stop_s","control_velocity_mms"]}}' || true
  echo
}

# Lab helpers removed for production installer.

do_cfg_reset() {
  require_repo
  require_paths

  if [[ ! -f "$DRIVER_CFG_DST" ]]; then
    echo "Driver config not found: $DRIVER_CFG_DST"
    echo "Run install first."
    exit 2
  fi
  if [[ ! -f "$CONTROLLER_CFG_DST" ]]; then
    echo "Controller config not found: $CONTROLLER_CFG_DST"
    echo "Run install first."
    exit 2
  fi

  local ts driver_backup controller_backup macros_backup
  ts="$(date +%Y%m%d_%H%M%S)"

  driver_backup="$DRIVER_CFG_DST.bak.$ts"
  cp "$DRIVER_CFG_DST" "$driver_backup"

  controller_backup="$CONTROLLER_CFG_DST.bak.$ts"
  cp "$CONTROLLER_CFG_DST" "$controller_backup"

  if [[ -f "$MACROS_DST" ]]; then
    macros_backup="$MACROS_DST.bak.$ts"
    cp "$MACROS_DST" "$macros_backup"
  fi

  cp "$DRIVER_CFG_TEMPLATE" "$DRIVER_CFG_DST"
  cp "$CONTROLLER_CFG_TEMPLATE" "$CONTROLLER_CFG_DST"
  cp "$MACROS_TEMPLATE" "$MACROS_DST"
  patch_cfg_if_needed

  echo "Reset driver config from template: $DRIVER_CFG_TEMPLATE -> $DRIVER_CFG_DST"
  echo "Reset controller config from template: $CONTROLLER_CFG_TEMPLATE -> $CONTROLLER_CFG_DST"
  echo "Reset macros from template: $MACROS_TEMPLATE -> $MACROS_DST"
  echo "Driver config backup saved: $driver_backup"
  echo "Controller config backup saved: $controller_backup"
  if [[ -n "${macros_backup:-}" ]]; then
    echo "Macros backup saved: $macros_backup"
  else
    echo "Macros backup: none (file did not exist before reset)"
  fi
}

usage() {
  cat <<USAGE
Usage: $0 <install|update|cfg-reset|purge|restart|status|logs|doctor>
USAGE
}

cmd="${1:-}"
case "$cmd" in
  install) do_install ;;
  update) do_update ;;
  cfg-reset) do_cfg_reset ;;
  purge) do_purge ;;
  restart) do_restart ;;
  status) do_status ;;
  logs) do_logs ;;
  doctor) do_doctor ;;
  *) usage; exit 2 ;;
esac
