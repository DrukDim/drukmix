#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
USER_NAME="$(id -un)"
EFFECTIVE_USER="${SUDO_USER:-$USER_NAME}"
USER_HOME=""

if [[ -z "${SUDO_USER:-}" && -n "${HOME:-}" ]]; then
  USER_HOME="$HOME"
fi
if [[ -z "$USER_HOME" ]]; then
  USER_HOME="$(getent passwd "$EFFECTIVE_USER" | cut -d: -f6 || true)"
fi
if [[ -z "$USER_HOME" ]]; then
  USER_HOME="$(python3 -c "import pwd; print(pwd.getpwnam('${EFFECTIVE_USER}').pw_dir)")"
fi
if [[ -z "$USER_HOME" ]]; then
  echo "Cannot determine user home directory"
  exit 2
fi

PRINTER_CFG_DIR="${PRINTER_CFG_DIR:-$USER_HOME/printer_data/config}"
PRINTER_LOG_DIR="${PRINTER_LOG_DIR:-$USER_HOME/printer_data/logs}"
PRINTER_CFG="$PRINTER_CFG_DIR/printer.cfg"
MOONRAKER_CFG="${MOONRAKER_CFG:-$PRINTER_CFG_DIR/moonraker.conf}"
KLIPPER_DIR="${KLIPPER_DIR:-$USER_HOME/klipper}"
MAINSAIL_CFG="$PRINTER_CFG_DIR/mainsail.cfg"

DRIVER_CFG_DST="$PRINTER_CFG_DIR/drukmix_driver.cfg"
CONTROLLER_CFG_DST="$PRINTER_CFG_DIR/drukmix_controller.cfg"
MACROS_DST="$PRINTER_CFG_DIR/drukmix_macros.cfg"
SERVICE_DST="/etc/systemd/system/drukmix.service"
UDEV_RULE_DST="/etc/udev/rules.d/99-drukos-bridge.rules"
KLIPPER_EXTRA_DST="$KLIPPER_DIR/klippy/extras/drukmix_planner_probe.py"
KLIPPER_CONTROLLER_DST="$KLIPPER_DIR/klippy/extras/drukmix_controller.py"
BRIDGE_ALIAS="/dev/drukos-bridge"
MOONRAKER_URL="${MOONRAKER_URL:-http://127.0.0.1:7125}"
DRIVER_CFG_TEMPLATE="$REPO_DIR/config_examples/drukmix_driver.cfg"
CONTROLLER_CFG_TEMPLATE="$REPO_DIR/config_examples/drukmix_controller.cfg"
MACROS_TEMPLATE="$REPO_DIR/config_examples/drukmix_macros.cfg"
SERVICE_TEMPLATE="$REPO_DIR/systemd/drukmix.service"
KLIPPER_EXTRA_SRC="$REPO_DIR/klipper_extra/drukmix_planner_probe.py"
KLIPPER_CONTROLLER_SRC="$REPO_DIR/klipper_extra/drukmix_controller.py"
SUPPORTED_PROFILES=("main" "brama" "duet")

print_header() {
  printf '\n== %s ==\n' "$1"
}

print_ok() {
  printf 'OK      %-24s %s\n' "$1" "$2"
}

print_warn() {
  printf 'WARN    %-24s %s\n' "$1" "$2"
}

print_missing() {
  printf 'MISSING %-24s %s\n' "$1" "$2"
}

print_info() {
  printf 'INFO    %-24s %s\n' "$1" "$2"
}

print_step() {
  printf '\n-- %s --\n' "$1"
}

file_state() {
  local path="$1"
  if [[ -e "$path" ]]; then
    print_ok "$2" "$path"
  else
    print_missing "$2" "$path"
  fi
}

git_value() {
  local args=("$@")
  if git -C "$REPO_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$REPO_DIR" "${args[@]}" 2>/dev/null || true
  fi
}

repo_branch() {
  git_value branch --show-current
}

repo_commit() {
  git_value rev-parse --short HEAD
}

repo_dirty() {
  local out
  out="$(git_value status --short)"
  if [[ -n "$out" ]]; then
    printf 'dirty'
  else
    printf 'clean'
  fi
}

require_repo_layout() {
  local missing=0
  for path in \
    "$REPO_DIR/drukmix_driver.py" \
    "$DRIVER_CFG_TEMPLATE" \
    "$CONTROLLER_CFG_TEMPLATE" \
    "$MACROS_TEMPLATE" \
    "$SERVICE_TEMPLATE" \
    "$KLIPPER_EXTRA_SRC" \
    "$KLIPPER_CONTROLLER_SRC"
  do
    if [[ ! -e "$path" ]]; then
      print_missing "repo file" "$path"
      missing=1
    fi
  done
  if [[ $missing -ne 0 ]]; then
    exit 2
  fi
}

require_python() {
  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 not found"
    exit 2
  fi
  if ! python3 -m venv --help >/dev/null 2>&1; then
    echo "python3-venv is required"
    exit 2
  fi
}

require_printer_stack_paths() {
  for path in "$PRINTER_CFG_DIR" "$PRINTER_LOG_DIR" "$KLIPPER_DIR" "$KLIPPER_DIR/klippy/extras"; do
    if [[ ! -e "$path" ]]; then
      echo "Required path not found: $path"
      exit 2
    fi
  done
  for path in "$PRINTER_CFG" "$MOONRAKER_CFG"; do
    if [[ ! -f "$path" ]]; then
      echo "Required file not found: $path"
      exit 2
    fi
  done
}

ensure_sudo_session() {
  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    return 0
  fi
  if ! command -v sudo >/dev/null 2>&1; then
    echo "sudo is required for this command"
    exit 2
  fi
  sudo -v
}

ensure_venv() {
  require_python
  if [[ ! -x "$REPO_DIR/.venv/bin/python" ]]; then
    python3 -m venv "$REPO_DIR/.venv"
  fi
  "$REPO_DIR/.venv/bin/python" -m pip install --upgrade pip setuptools wheel
  if [[ -f "$REPO_DIR/requirements.txt" ]]; then
    "$REPO_DIR/.venv/bin/pip" install -r "$REPO_DIR/requirements.txt"
  fi
}

compile_check() {
  "$REPO_DIR/.venv/bin/python" -m py_compile \
    "$REPO_DIR/drukmix_driver.py" \
    "$REPO_DIR/backend/pump_backend_base.py" \
    "$REPO_DIR/backend/backend_pumpvfd.py" \
    "$REPO_DIR/backend/backend_pumptpl.py" \
    "$REPO_DIR/backend/bridge_usb_transport.py" \
    "$REPO_DIR/backend/vfd_faults.py"
}

profile_supported() {
  local profile="$1"
  local item
  for item in "${SUPPORTED_PROFILES[@]}"; do
    if [[ "$item" == "$profile" ]]; then
      return 0
    fi
  done
  return 1
}

service_state() {
  local name="$1"
  if ! command -v systemctl >/dev/null 2>&1; then
    printf 'unavailable'
    return 0
  fi
  if ! systemctl list-unit-files "$name" >/dev/null 2>&1; then
    printf 'not-installed'
    return 0
  fi
  local active
  active="$(systemctl is-active "$name" 2>/dev/null || true)"
  if [[ -z "$active" ]]; then
    printf 'not-installed'
  else
    printf '%s' "$active"
  fi
}

service_runtime_state() {
  local name="$1"
  if ! command -v systemctl >/dev/null 2>&1; then
    printf 'unavailable'
    return 0
  fi
  if ! systemctl list-unit-files "$name" >/dev/null 2>&1; then
    printf 'not-installed'
    return 0
  fi

  local active sub result
  active="$(systemctl show "$name" -p ActiveState --value 2>/dev/null || true)"
  sub="$(systemctl show "$name" -p SubState --value 2>/dev/null || true)"
  result="$(systemctl show "$name" -p Result --value 2>/dev/null || true)"

  if [[ "$active" == "activating" && "$sub" == "auto-restart" ]]; then
    printf 'restart-loop'
    return 0
  fi
  if [[ "$active" == "failed" || "$result" == "exit-code" && "$active" != "active" ]]; then
    printf 'failed'
    return 0
  fi
  if [[ -n "$active" ]]; then
    printf '%s' "$active"
  else
    printf 'unknown'
  fi
}

moonraker_info() {
  if ! command -v curl >/dev/null 2>&1; then
    return 1
  fi
  curl -fsS "$MOONRAKER_URL/server/info" 2>/dev/null || return 1
}

moonraker_reachable() {
  moonraker_info >/dev/null
}

klipper_ready() {
  local info
  info="$(moonraker_info || true)"
  [[ "$info" == *'"klippy_state":"ready"'* ]]
}

has_moonraker_update_manager() {
  [[ -f "$MOONRAKER_CFG" ]] && grep -Fq "[update_manager drukmix]" "$MOONRAKER_CFG"
}

printer_cfg_has_line() {
  local needle="$1"
  [[ -f "$PRINTER_CFG" ]] && grep -Fqx "$needle" "$PRINTER_CFG"
}

printer_cfg_has_managed_probe_block() {
  [[ -f "$PRINTER_CFG" ]] \
    && grep -Fq "# --- drukmix planner probe (managed): begin ---" "$PRINTER_CFG" \
    && grep -Fq "# --- drukmix planner probe (managed): end ---" "$PRINTER_CFG"
}

bridge_alias_exists() {
  [[ -e "$BRIDGE_ALIAS" || -L "$BRIDGE_ALIAS" ]]
}

bridge_usb_visible() {
  [[ -d /dev/serial/by-id ]] && ls /dev/serial/by-id 2>/dev/null | grep -Ei 'cp210|drukos-bridge|usb-.*bridge' >/dev/null
}

moonraker_write_update_manager() {
  MOONRAKER_CFG="$MOONRAKER_CFG" USER_HOME="$USER_HOME" python3 - <<'PY'
from pathlib import Path
import os

p = Path(os.environ["MOONRAKER_CFG"])
user_home = os.environ["USER_HOME"]
text = p.read_text()
section = f"""[update_manager drukmix]
type: git_repo
path: {user_home}/drukmix
origin: https://github.com/DrukDim/drukmix.git
primary_branch: main
"""

lines = text.splitlines()
out = []
i = 0
while i < len(lines):
    if lines[i].strip() == "[update_manager drukmix]":
        i += 1
        while i < len(lines) and not (lines[i].startswith("[") and lines[i].endswith("]")):
            i += 1
        while i < len(lines) and lines[i].strip() == "":
            i += 1
        continue
    out.append(lines[i])
    i += 1

new_text = "\n".join(out).rstrip() + "\n\n" + section
p.write_text(new_text)
PY
}

install_cfg_if_missing() {
  if [[ ! -f "$DRIVER_CFG_DST" ]]; then
    cp "$DRIVER_CFG_TEMPLATE" "$DRIVER_CFG_DST"
    print_ok "driver cfg" "installed"
  else
    print_info "driver cfg" "kept existing"
  fi
  if [[ ! -f "$CONTROLLER_CFG_DST" ]]; then
    cp "$CONTROLLER_CFG_TEMPLATE" "$CONTROLLER_CFG_DST"
    print_ok "controller cfg" "installed"
  else
    print_info "controller cfg" "kept existing"
  fi
  if [[ ! -f "$MACROS_DST" ]]; then
    cp "$MACROS_TEMPLATE" "$MACROS_DST"
    print_ok "macros cfg" "installed"
  else
    print_info "macros cfg" "kept existing"
  fi
}

patch_driver_cfg() {
  DRIVER_CFG_DST="$DRIVER_CFG_DST" USER_HOME="$USER_HOME" PRINTER_LOG_DIR="$PRINTER_LOG_DIR" python3 - <<'PY'
from pathlib import Path
import os

p = Path(os.environ["DRIVER_CFG_DST"])
user_home = os.environ["USER_HOME"]
log_dir = os.environ["PRINTER_LOG_DIR"]
log_file = f"{log_dir}/drukmix_driver.log"
s = p.read_text()
repl = {
    "/home/dan/": user_home + "/",
    "/home/drukos/": user_home + "/",
    "/root/": user_home + "/",
    "log_file = /var/log/drukmix/drukmix_driver.log": f"log_file = {log_file}",
    "log_file = /home/drukos/printer_data/logs/drukmix_driver.log": f"log_file = {log_file}",
    "log_file = /home/dan/printer_data/logs/drukmix_driver.log": f"log_file = {log_file}",
    "log_file = /root/printer_data/logs/drukmix_driver.log": f"log_file = {log_file}",
}
for a, b in repl.items():
    s = s.replace(a, b)
if "client_name =" not in s:
    s += "\nclient_name = drukmix_driver\nclient_version = 1.0\nclient_type = agent\nclient_url = http://127.0.0.1\n"
if "log_file =" not in s:
    s += f"\nlog_file = {log_file}\n"
p.write_text(s)
PY
}

install_klipper_extras() {
  install -m 0644 "$KLIPPER_EXTRA_SRC" "$KLIPPER_EXTRA_DST"
  install -m 0644 "$KLIPPER_CONTROLLER_SRC" "$KLIPPER_CONTROLLER_DST"
}

install_service_unit() {
  local rendered
  rendered="$(mktemp)"
  sed \
    -e "s|^User=.*$|User=${USER_NAME}|" \
    -e "s|^WorkingDirectory=.*$|WorkingDirectory=${REPO_DIR}|" \
    -e "s|^Environment=.*$|Environment=DRUKMIX_CONFIG=${DRIVER_CFG_DST}|" \
    -e "s|^ExecStart=.*$|ExecStart=${REPO_DIR}/.venv/bin/python ${REPO_DIR}/drukmix_driver.py|" \
    "$SERVICE_TEMPLATE" > "$rendered"
  sudo install -m 0644 "$rendered" "$SERVICE_DST"
  rm -f "$rendered"
  sudo systemctl daemon-reload
}

install_bridge_udev_rule() {
  sudo mkdir -p "$(dirname "$UDEV_RULE_DST")"
  sudo tee "$UDEV_RULE_DST" >/dev/null <<'EOF'
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", ATTRS{serial}=="0001", SYMLINK+="drukos-bridge", MODE:="0660", GROUP:="dialout"
EOF
  sudo chmod 0644 "$UDEV_RULE_DST"
}

reload_udev_rules() {
  if command -v udevadm >/dev/null 2>&1; then
    sudo udevadm control --reload-rules >/dev/null 2>&1 || true
    sudo udevadm trigger >/dev/null 2>&1 || true
    udevadm settle >/dev/null 2>&1 || true
  fi
}

patch_mainsail_pause_no_park() {
  if [[ ! -f "$MAINSAIL_CFG" ]]; then
    return 0
  fi
  MAINSAIL_CFG="$MAINSAIL_CFG" python3 - <<'PY'
from pathlib import Path
import os

p = Path(os.environ["MAINSAIL_CFG"])
s = p.read_text()
old_pause = "  _TOOLHEAD_PARK_PAUSE_CANCEL {rawparams}\n"
old_cancel = "  {% if (custom_park or not printer.pause_resume.is_paused) and allow_park %} _TOOLHEAD_PARK_PAUSE_CANCEL {park_x} {park_y} {% endif %}\n"
changed = False
if old_pause in s:
    s = s.replace(old_pause, "")
    changed = True
if old_cancel in s:
    s = s.replace(old_cancel, "")
    changed = True
if changed:
    p.write_text(s)
PY
}

ensure_printer_integration() {
  PRINTER_CFG="$PRINTER_CFG" CONTROLLER_CFG_DST="$CONTROLLER_CFG_DST" python3 - <<'PY'
from pathlib import Path
import configparser
import os
import re

p = Path(os.environ["PRINTER_CFG"])
controller_cfg = Path(os.environ["CONTROLLER_CFG_DST"])
s = p.read_text()

for needle in ("[include drukmix_controller.cfg]", "[include drukmix_macros.cfg]"):
    lines = s.splitlines()
    if needle not in [line.strip() for line in lines]:
        s = s.rstrip("\n") + "\n" + needle + "\n"

begin = "# --- drukmix planner probe (managed): begin ---"
end = "# --- drukmix planner probe (managed): end ---"
if begin in s and end in s:
    a = s.index(begin)
    b = s.index(end) + len(end)
    s = (s[:a] + s[b:]).rstrip("\n") + "\n"

s = re.sub(r"(?ms)^\[drukmix_planner_probe\]\s*\n.*?(?=^\[|\Z)", "", s).rstrip("\n")

host_buffer_target_s = 3.0
cp = configparser.ConfigParser(inline_comment_prefixes=("#", ";"))
if controller_cfg.exists():
    try:
        cp.read(controller_cfg)
        if cp.has_section("drukmix_controller"):
            host_buffer_target_s = cp.getfloat("drukmix_controller", "pump_start_lookahead_s", fallback=3.0)
    except Exception:
        host_buffer_target_s = 3.0

block = f"""# --- drukmix planner probe (managed): begin ---
[drukmix_planner_probe]
extruder = extruder
debug_enabled = False
debug_every_n_moves = 200
print_velocity_epsilon = 0.001000
print_gap_merge_s = 0.750
host_buffer_target_s = {host_buffer_target_s:.3f}
# --- drukmix planner probe (managed): end ---"""

s = s.rstrip("\n") + "\n\n" + block + "\n"
p.write_text(s)
PY
}

restart_moonraker_if_possible() {
  if command -v systemctl >/dev/null 2>&1 && systemctl list-unit-files moonraker.service >/dev/null 2>&1; then
    sudo systemctl restart moonraker.service || true
  fi
}

restart_klipper_if_possible() {
  if moonraker_reachable; then
    curl -fsS -X POST "$MOONRAKER_URL/printer/gcode/script" \
      -H 'Content-Type: application/json' \
      -d '{"script":"RESTART"}' >/dev/null || true
  fi
}

wait_klipper_ready() {
  local n=0
  while [[ $n -lt 30 ]]; do
    if klipper_ready; then
      return 0
    fi
    sleep 1
    n=$((n+1))
  done
  return 1
}

enable_runtime_if_ready() {
  if bridge_alias_exists; then
    sudo systemctl enable drukmix.service >/dev/null 2>&1 || true
    sudo systemctl restart drukmix.service
    print_ok "runtime" "drukmix.service enabled and started"
  else
    sudo systemctl disable drukmix.service >/dev/null 2>&1 || true
    print_warn "runtime" "bridge missing, service not started"
  fi
}

remove_file_if_exists() {
  local path="$1"
  if [[ -e "$path" || -L "$path" ]]; then
    rm -f "$path"
  fi
}

remove_path_any_owner() {
  local path="$1"
  if [[ ! -e "$path" && ! -L "$path" ]]; then
    return 0
  fi
  if rm -rf "$path" 2>/dev/null; then
    return 0
  fi
  sudo rm -rf "$path"
}

