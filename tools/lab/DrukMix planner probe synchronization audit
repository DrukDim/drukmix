        self.gain_pct = config.getfloat('gain_pct', 100.0)
        # ... інші параметри

        # State machine
        self.state = "idle"  # idle / prestart / printing / prestop
        self.target_pct = 0.0
        self.reverse = False

        # References (resolved on connect)
        self.probe = None  # drukmix_planner_probe

        # Register G-code commands
        gcode = self.printer.lookup_object('gcode')
        gcode.register_command('DRUKMIX_STOP', self.cmd_DRUKMIX_STOP)
        gcode.register_command('DRUKMIX_FLUSH', self.cmd_DRUKMIX_FLUSH)
        gcode.register_command('DRUKMIX_SET_GAIN', self.cmd_DRUKMIX_SET_GAIN)
        # ...

        # Reactor timer for state machine updates
        self.printer.register_event_handler("klippy:connect", self._handle_connect)

    def _handle_connect(self):
        self.probe = self.printer.lookup_object('drukmix_planner_probe', None)
        # Start reactor timer - runs every ~50ms in Klipper's own event loop
        self.reactor.register_timer(self._update_pump_state, self.reactor.NOW)

    def _update_pump_state(self, eventtime):
        """Called by Klipper reactor. Direct access to probe - zero latency."""
        if self.probe is None:
            self.state = "idle"
            self.target_pct = 0.0
            return eventtime + 0.25  # retry

        # Read probe data DIRECTLY - no Moonraker, no websocket, no latency
        probe_status = self.probe.get_status(eventtime)

        # State machine logic (same as current agent, but simpler and faster)
        # ... IDLE → PRESTART → PRINTING → PRESTOP
        self._decide(probe_status, eventtime)

        return eventtime + 0.1  # 10Hz state machine, light on CPU

    def get_status(self, eventtime):
        """Exposed to Moonraker/agent via standard Klipper status mechanism."""
        return {
            'pump_state': self.state,
            'target_pct': self.target_pct,
            'reverse': self.reverse,
            'control_velocity_mms': self._last_velocity,
            # ... bridge-facing command intent
        }
